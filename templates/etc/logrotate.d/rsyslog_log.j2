{{ file_managed_by_ansible }}

/var/log/rsyslog/*.log {
    {{ bozkarcis_rsyslog_logrotate_rotated_when }}
    rotate {{ bozkarcis_rsyslog_logrotate_rotatation_keep }}
{% if bozkarcis_rsyslog_logrotate_compress %}
    compress
{% else %}
    nocompress
{% endif %}
{% if bozkarcis_rsyslog_logrotate_missingok %}
    missingok
{% else %}
    nomissingok
{% endif %}
{% if bozkarcis_rsyslog_logrotate_notifempty %}
    notifempty
{% else %}
    ifempty
{% endif %}
{% if bozkarcis_rsyslog_logrotate_create %}
    create{% if bozkarcis_rsyslog_logrotate_create_opts is defined %} {{ bozkarcis_rsyslog_logrotate_create_opts }}{% endif %}
{% endif %}

    postrotate
        /usr/bin/systemctl reload rsyslog.service >/dev/null || true
    endscript
}
